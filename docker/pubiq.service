[Unit]
Description=Pub-IQ API (docker compose stack)
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/pubiq
ExecStart=/usr/bin/docker compose --project-directory /opt/pubiq -f docker/docker-compose.yml up -d --build
ExecStop=/usr/bin/docker compose --project-directory /opt/pubiq -f docker/docker-compose.yml down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target

# --- LLM provider ---
# LiteLLM-style provider/model string. DSPy 3.x reads this directly.
LLM_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Bedrock alternative (uncomment and fill to use instead of direct Anthropic)
# LLM_MODEL=bedrock/anthropic.claude-sonnet-4-6-v1:0
# AWS_REGION=eu-west-3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=default

# --- TikTok platform adapter ---
# Register at https://developers.tiktok.com — Research API requires app audit approval.
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/auth/tiktok/callback

# --- API auth ---
# Comma-separated API keys, one per tenant, for early pilots.
# Required — no default. The app will refuse to start if this is unset.
API_KEYS=change-me-before-deploy

# --- Database (Postgres) ---
# Required for DBOS workflows, baseline storage, token persistence, audit records.
# Local dev: docker compose -f docker/docker-compose.yml up -d
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev
POSTGRES_DB=omicron
DATABASE_URL=postgresql://postgres:dev@localhost:5432/omicron

# --- Audit / EU AI Act compliance ---
AUDIT_LOG_PATH=./audit.log

# --- Agent execution timeout ---
AGENT_TIMEOUT_S=120

# --- Compiled DSPy artifact (generated by: make compile-insight) ---
COMPILED_INSIGHT_PATH=data/compiled/insight_agent.json

# --- E2E tests (make e2e / make e2e-live) ---
# A dedicated key that is safe to use in test runs. Must be present in API_KEYS above.
E2E_API_KEY=change-me-before-deploy

# --- MCP adapter (only needed if running the mcp/server.py process) ---
OMICRON_API_BASE_URL=http://localhost:8000
OMICRON_API_KEY=dev-key-change-me
